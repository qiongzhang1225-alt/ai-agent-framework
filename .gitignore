# ── 环境变量与密钥 ────────────────────────────────────────────────────
.env
.env.local

# ── Python ──────────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# ── 运行时数据（用户私有，不入 git）──────────────────────────────────
# ⚠ gitignore 不支持「模式 + 行内注释」：注释必须独占一行，否则整行被当字面模式 → 规则失效、私有数据被提交
# .sandbox/=对话历史+workspace   .memory/=ChromaDB 向量库
# .skills_trash/=删技能回收站(7天)   .skills_backups/ .memory_backups/=定期备份
# .execute_trash/=execute_code 覆盖前快照(7天)
.sandbox/
.memory/
.skills_trash/
.skills_backups/
.memory_backups/
.execute_trash/

# ── launcher 运行时 ─────────────────────────────────────────────────
# .yuki.lock=单实例锁   .yuki-launcher.log=exe 日志
.yuki.lock
.yuki-launcher.log

# ── 备份文件 ────────────────────────────────────────────────────────
*.bak
*.bak2
*.bak3
# conv.json.pre-*.bak（主对话压缩前快照）—— 已被上面 *.bak 覆盖，保留此行表意
conv.json.pre-*.bak

# ── 本地 embedding 模型（390MB，用户自行下载）────────────────────────
models/*
!models/README.md

# ── 桌面打包产物 ────────────────────────────────────────────────────
build/
dist/
*.spec.bak
# build.bat 复制到根目录的运行入口
/yuki.exe
/_internal/

# ── IDE / 编辑器 ────────────────────────────────────────────────────
.idea/
.vscode/
.obsidian/

# ── 操作系统垃圾 ────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ── 发行 zip（release.bat 产物）/ 临时调试脚本，别入 git ─────────────
/yuki-source-*.zip
/.test_*.py

# ── 用户的个人背景图 / 图标（默认带的图保留在 git 里，覆盖时用户自己改）
# 不忽略 assets/，因为默认带的图属于"开箱即用"内容
