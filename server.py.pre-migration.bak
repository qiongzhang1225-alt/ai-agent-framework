"""FastAPI 后端 —— 替代 Streamlit，提供自由可定制的 UI。

后端职责：
- 管理对话（内存中的会话状态）
- 工作目录 CRUD
- SSE 流式聊天接口
- 文件上传 / 下载 / 预览
- 工作目录文件列表
"""

from __future__ import annotations

import asyncio
import json
import mimetypes
import uuid
from contextlib import asynccontextmanager
from pathlib import Path
from typing import Any, AsyncIterator

import aiosqlite
from fastapi import FastAPI, File, HTTPException, Request, UploadFile
from fastapi.responses import FileResponse, HTMLResponse, JSONResponse
from fastapi.staticfiles import StaticFiles
from fastapi.templating import Jinja2Templates
from pydantic import BaseModel
from sse_starlette.sse import EventSourceResponse
from langchain_core.messages import HumanMessage
from langgraph.checkpoint.sqlite.aio import AsyncSqliteSaver

from agent import _PROJECT_ROOT, create_agent

# ── 配置 ─────────────────────────────────────────────────────────────────────

WORKSPACE_ROOT = _PROJECT_ROOT / ".sandbox" / "workspace"
META_ROOT = _PROJECT_ROOT / ".sandbox" / "_meta"
CHECKPOINT_DB = _PROJECT_ROOT / ".sandbox" / "checkpoints.db"
ASSETS_DIR = _PROJECT_ROOT / "assets"
STATIC_DIR = _PROJECT_ROOT / "static"
TEMPLATES_DIR = _PROJECT_ROOT / "templates"

MODELS: dict[str, str] = {
    "deepseek-v4-flash": "DeepSeek V4 Flash",
    "deepseek-v4-pro": "DeepSeek V4 Pro",
}
DEFAULT_MODEL = "deepseek-v4-flash"

# ── App ──────────────────────────────────────────────────────────────────────


@asynccontextmanager
async def lifespan(app: FastAPI):
    """启动时打开 aiosqlite + AsyncSqliteSaver，关闭时释放。"""
    global _aio_conn, _checkpointer
    _aio_conn = await aiosqlite.connect(str(CHECKPOINT_DB))
    _checkpointer = AsyncSqliteSaver(_aio_conn)
    await _checkpointer.setup()  # 幂等建表（checkpoints / writes）
    try:
        yield
    finally:
        if _aio_conn is not None:
            await _aio_conn.close()


app = FastAPI(title="信息统合思念体", lifespan=lifespan)
templates = Jinja2Templates(directory=str(TEMPLATES_DIR))
app.mount("/static", StaticFiles(directory=str(STATIC_DIR)), name="static")
app.mount("/assets", StaticFiles(directory=str(ASSETS_DIR)), name="assets")

# ── 持久化基础设施 ───────────────────────────────────────────────────────────

CHECKPOINT_DB.parent.mkdir(parents=True, exist_ok=True)
# AsyncSqliteSaver 必须在 async 环境中初始化，由 lifespan 在 startup 阶段填充。
_aio_conn: aiosqlite.Connection | None = None
_checkpointer: AsyncSqliteSaver | None = None

# ── 全局状态 ─────────────────────────────────────────────────────────────────

_agents: dict[str, Any] = {}  # model_id -> agent 实例


def get_agent(model_id: str):
    if model_id not in _agents:
        _agents[model_id] = create_agent(model_id, checkpointer=_checkpointer)
    return _agents[model_id]


# 会话：{thread_id: {id, name, messages, workdir, model}}
conversations: dict[str, dict] = {}


def _conv_json_path(tid: str) -> Path:
    return META_ROOT / tid / "conv.json"


def _save_conv(conv: dict) -> None:
    """把单个对话原子写入磁盘（先写 .tmp 再 rename，避免崩溃时写到一半坏文件）。"""
    path = _conv_json_path(conv["id"])
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(
        json.dumps(conv, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    tmp.replace(path)


async def _delete_conv_persist(tid: str) -> None:
    """删除对话的所有持久化痕迹（conv.json + LangGraph checkpoint 行）。"""
    path = _conv_json_path(tid)
    if path.exists():
        path.unlink()
    if _aio_conn is None:
        return
    # 不同 langgraph 版本表名可能不同，全部尝试一遍
    for table in ("checkpoints", "writes", "checkpoint_writes", "checkpoint_blobs"):
        try:
            await _aio_conn.execute(
                f"DELETE FROM {table} WHERE thread_id = ?", (tid,)
            )
        except Exception:
            pass
    try:
        await _aio_conn.commit()
    except Exception:
        pass


def _load_all_conversations() -> None:
    """启动时调用：扫描 META_ROOT 下所有 conv.json，加载进内存。"""
    if not META_ROOT.exists():
        return
    # 按修改时间排序，最近用的对话排在前面
    dirs = [d for d in META_ROOT.iterdir() if d.is_dir()]
    dirs.sort(key=lambda p: p.stat().st_mtime)
    for d in dirs:
        path = d / "conv.json"
        if not path.exists():
            continue
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
            # 校验 workdir 仍存在；如不存在尝试重建（用户可能改过路径）
            if data.get("workdir"):
                try:
                    Path(data["workdir"]).mkdir(parents=True, exist_ok=True)
                except Exception:
                    pass
            conversations[data["id"]] = data
        except Exception as e:
            print(f"[warn] failed to load {path}: {e}")


# 模块导入时（server 启动时）立即加载持久化的会话
_load_all_conversations()


def new_conversation(model_id: str = DEFAULT_MODEL) -> dict:
    tid = str(uuid.uuid4())
    workdir = WORKSPACE_ROOT / tid
    workdir.mkdir(parents=True, exist_ok=True)
    conv = {
        "id": tid,
        "name": "新对话",
        "messages": [],
        "workdir": str(workdir),
        "model": model_id,
    }
    conversations[tid] = conv
    _save_conv(conv)
    return conv


def _list_workdir_files(workdir: str) -> set[Path]:
    root = Path(workdir)
    if not root.exists():
        return set()
    return {p for p in root.rglob("*") if p.is_file()}


def _safe_path(workdir: str, relpath: str) -> Path:
    """把相对路径解析为绝对路径，并校验落在 workdir 内（防 path traversal）。"""
    workdir_abs = Path(workdir).resolve()
    target = (workdir_abs / relpath).resolve()
    try:
        target.relative_to(workdir_abs)
    except ValueError:
        raise HTTPException(403, "Path escapes workdir")
    return target


# ── 首页 ─────────────────────────────────────────────────────────────────────

@app.get("/", response_class=HTMLResponse)
async def index(request: Request):
    if not conversations:
        new_conversation()
    has_bg = any(
        (ASSETS_DIR / f"background.{ext}").exists()
        for ext in ("png", "jpg", "jpeg", "webp")
    )
    bg_url = None
    if has_bg:
        for ext in ("png", "jpg", "jpeg", "webp"):
            if (ASSETS_DIR / f"background.{ext}").exists():
                bg_url = f"/assets/background.{ext}"
                break
    has_icon = (ASSETS_DIR / "icon.png").exists()
    return templates.TemplateResponse(
        request,
        "index.html",
        {
            "models": MODELS,
            "default_model": DEFAULT_MODEL,
            "background_url": bg_url,
            "icon_url": "/assets/icon.png" if has_icon else None,
        },
    )


# ── 会话 CRUD ────────────────────────────────────────────────────────────────

def _conv_summary(conv: dict) -> dict:
    return {
        "id": conv["id"],
        "name": conv["name"],
        "workdir": conv["workdir"],
        "model": conv["model"],
        "message_count": len(conv["messages"]),
    }


@app.get("/api/conversations")
async def list_conversations() -> list[dict]:
    # 倒序：最新创建的在前
    return [_conv_summary(c) for c in reversed(list(conversations.values()))]


@app.get("/api/conversations/{tid}")
async def get_conversation(tid: str) -> dict:
    if tid not in conversations:
        raise HTTPException(404, "Conversation not found")
    return conversations[tid]


class CreateConvRequest(BaseModel):
    model: str = DEFAULT_MODEL


@app.post("/api/conversations")
async def create_conversation(req: CreateConvRequest) -> dict:
    if req.model not in MODELS:
        raise HTTPException(400, "Unknown model")
    return new_conversation(req.model)


@app.delete("/api/conversations/{tid}")
async def delete_conversation(tid: str):
    if tid not in conversations:
        raise HTTPException(404, "Conversation not found")
    del conversations[tid]
    await _delete_conv_persist(tid)
    if not conversations:
        new_conversation()
    return {"ok": True}


class UpdateConvRequest(BaseModel):
    name: str | None = None
    workdir: str | None = None
    model: str | None = None


@app.patch("/api/conversations/{tid}")
async def update_conversation(tid: str, req: UpdateConvRequest) -> dict:
    if tid not in conversations:
        raise HTTPException(404, "Conversation not found")
    conv = conversations[tid]
    if req.name is not None:
        conv["name"] = req.name.strip() or "未命名"
    if req.workdir is not None:
        try:
            path = Path(req.workdir).expanduser().resolve()
            path.mkdir(parents=True, exist_ok=True)
            conv["workdir"] = str(path)
        except Exception as e:
            raise HTTPException(400, f"Invalid workdir: {e}")
    if req.model is not None:
        if req.model not in MODELS:
            raise HTTPException(400, "Unknown model")
        conv["model"] = req.model
    _save_conv(conv)
    return conv


# ── SSE 聊天 ─────────────────────────────────────────────────────────────────

class ChatRequest(BaseModel):
    thread_id: str
    message: str


@app.post("/api/chat")
async def chat(req: ChatRequest):
    if req.thread_id not in conversations:
        raise HTTPException(404, "Conversation not found")
    conv = conversations[req.thread_id]

    if conv["name"] == "新对话":
        conv["name"] = req.message[:18] + ("…" if len(req.message) > 18 else "")

    conv["messages"].append({"role": "user", "content": req.message})
    _save_conv(conv)
    files_before = _list_workdir_files(conv["workdir"])

    async def event_gen() -> AsyncIterator[dict]:
        agent_obj = get_agent(conv["model"])
        cfg = {
            "configurable": {
                "thread_id": conv["id"],
                "workdir": conv["workdir"],
            }
        }
        full_response = ""
        try:
            async for chunk, metadata in agent_obj.astream(
                {"messages": [HumanMessage(content=req.message)]},
                config=cfg,
                stream_mode="messages",
            ):
                node = metadata.get("langgraph_node", "")
                if node == "tools":
                    tool_name = getattr(chunk, "name", None)
                    if tool_name:
                        yield {
                            "event": "tool_call",
                            "data": json.dumps({"tool": tool_name}),
                        }
                elif node == "agent":
                    content = getattr(chunk, "content", "")
                    if isinstance(content, str) and content:
                        full_response += content
                        yield {
                            "event": "delta",
                            "data": json.dumps({"text": content}),
                        }
        except Exception as e:
            yield {
                "event": "error",
                "data": json.dumps({"error": str(e)}),
            }
            full_response = full_response or f"[错误] {e}"

        # 扫描新生成的文件
        files_after = _list_workdir_files(conv["workdir"])
        workdir_abs = Path(conv["workdir"]).resolve()
        new_files_rel = sorted(
            str(p.resolve().relative_to(workdir_abs)).replace("\\", "/")
            for p in (files_after - files_before)
        )

        conv["messages"].append({
            "role": "assistant",
            "content": full_response,
            "files": new_files_rel,
        })
        _save_conv(conv)

        yield {
            "event": "done",
            "data": json.dumps({
                "full": full_response,
                "new_files": new_files_rel,
                "conv_name": conv["name"],
            }),
        }

    return EventSourceResponse(event_gen())


# ── 文件上传 / 列表 / 预览 / 下载 ────────────────────────────────────────────

@app.post("/api/conversations/{tid}/upload")
async def upload_files(tid: str, files: list[UploadFile] = File(...)):
    if tid not in conversations:
        raise HTTPException(404, "Conversation not found")
    workdir = Path(conversations[tid]["workdir"])
    workdir.mkdir(parents=True, exist_ok=True)
    saved = []
    for f in files:
        # 安全：只取 basename
        name = Path(f.filename or "upload.bin").name
        dest = workdir / name
        # 同名冲突 → 加后缀
        if dest.exists():
            stem, suf = dest.stem, dest.suffix
            i = 1
            while dest.exists():
                dest = workdir / f"{stem}_{i}{suf}"
                i += 1
        with open(dest, "wb") as out:
            out.write(await f.read())
        saved.append(dest.name)
    return {"saved": saved}


@app.get("/api/conversations/{tid}/files")
async def list_files(tid: str):
    """列出工作目录所有文件（相对路径 + 大小）。"""
    if tid not in conversations:
        raise HTTPException(404, "Conversation not found")
    workdir = Path(conversations[tid]["workdir"]).resolve()
    if not workdir.exists():
        return []
    out = []
    for p in sorted(workdir.rglob("*")):
        if p.is_file():
            rel = str(p.relative_to(workdir)).replace("\\", "/")
            out.append({"path": rel, "size": p.stat().st_size})
    return out


@app.get("/api/conversations/{tid}/file")
async def get_file(tid: str, path: str, download: bool = False):
    """读取工作目录内文件，用于预览（<img>）或下载。"""
    if tid not in conversations:
        raise HTTPException(404, "Conversation not found")
    target = _safe_path(conversations[tid]["workdir"], path)
    if not target.exists() or not target.is_file():
        raise HTTPException(404, "File not found")
    mime, _ = mimetypes.guess_type(target.name)
    if download:
        return FileResponse(target, filename=target.name, media_type=mime or "application/octet-stream")
    return FileResponse(target, media_type=mime or "application/octet-stream")


# ── 长期记忆 API ──────────────────────────────────────────────────────────────


class AddMemoryRequest(BaseModel):
    fact: str


@app.get("/api/memory")
async def list_memory():
    from memory import list_memories
    return list_memories()


@app.post("/api/memory")
async def add_memory_route(req: AddMemoryRequest):
    from memory import add_memory
    try:
        mem_id = add_memory(req.fact)
    except ValueError as e:
        raise HTTPException(400, str(e))
    return {"id": mem_id, "fact": req.fact}


@app.delete("/api/memory/{mem_id}")
async def delete_memory_route(mem_id: str):
    from memory import delete_memory
    delete_memory(mem_id)
    return {"ok": True}


# ── 健康检查 ─────────────────────────────────────────────────────────────────

@app.get("/api/health")
async def health():
    from memory import count_memories
    try:
        mem_count = count_memories()
    except Exception:
        mem_count = -1
    return {
        "status": "ok",
        "models": list(MODELS),
        "conversations": len(conversations),
        "memories": mem_count,
    }


# ── 入口 ─────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    import socket
    import threading
    import time
    import webbrowser
    import uvicorn

    PORT = 3616
    URL = f"http://127.0.0.1:{PORT}"

    def _open_browser_when_ready():
        """轮询端口直到 uvicorn 真正接受连接，再唤醒浏览器；最多等 10 秒。"""
        deadline = time.time() + 10
        while time.time() < deadline:
            try:
                with socket.create_connection(("127.0.0.1", PORT), timeout=0.3):
                    webbrowser.open(URL)
                    return
            except OSError:
                time.sleep(0.2)

    threading.Thread(target=_open_browser_when_ready, daemon=True).start()
    uvicorn.run("server:app", host="127.0.0.1", port=PORT, reload=False)
