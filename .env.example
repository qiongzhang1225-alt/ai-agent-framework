# 复制此文件为 .env，填入对应的 API Key

# ─── 主对话模型 ────────────────────────────────────────────────────
# DeepSeek（默认对话 / 推理）
DEEPSEEK_API_KEY=your_deepseek_key_here

# ─── 视觉模型（看图）─────────────────────────────────────────────
# 任何 OpenAI Vision 协议兼容的端点都能直连。三件套全配齐即生效；
# 任一未配 → 自动回退到下方 MIMO_API_KEY（向后兼容）。
#
# 推荐选择（按价位 / 体验，按需取消注释一组）：
#
#   # OpenAI（贵但稳）
#   # VISION_BASE_URL=https://api.openai.com/v1
#   # VISION_API_KEY=sk-...
#   # VISION_MODEL=gpt-4o-mini
#
#   # 火山方舟 / 豆包视觉（国内速度好）
#   # VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#   # VISION_API_KEY=...
#   # VISION_MODEL=doubao-vision-pro-32k
#
#   # 通义千问 VL
#   # VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   # VISION_API_KEY=sk-...
#   # VISION_MODEL=qwen-vl-max
#
#   # 智谱 GLM-4V
#   # VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   # VISION_API_KEY=...
#   # VISION_MODEL=glm-4v
#
#   # 硅基流动（聚合各家开源 VL 模型，按 token 计费）
#   # VISION_BASE_URL=https://api.siliconflow.cn/v1
#   # VISION_API_KEY=sk-...
#   # VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct
#
#   # OpenRouter（聚合 Claude / Gemini / 各家闭源）
#   # VISION_BASE_URL=https://openrouter.ai/api/v1
#   # VISION_API_KEY=sk-or-...
#   # VISION_MODEL=anthropic/claude-3.5-sonnet
#
#   # Ollama 本地（免费但小模型效果一般）
#   # VISION_BASE_URL=http://localhost:11434/v1
#   # VISION_API_KEY=ollama
#   # VISION_MODEL=qwen2-vl

# ─── 兼容旧版（小米 MiMo） ────────────────────────────────────────
# 上面 VISION_* 三件套未配齐时，工具回退到 MiMo
# 申请: https://platform.xiaomimimo.com
# 都不用视觉就两个 key 都留空（图片功能会报错"未配置"但不影响对话）
MIMO_API_KEY=your_mimo_key_here
