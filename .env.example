# 复制此文件为 .env，填入对应的 API Key

# ─── 主对话模型 ────────────────────────────────────────────────────
# DeepSeek（默认对话 / 推理）
DEEPSEEK_API_KEY=your_deepseek_key_here

# ─── 视觉模型路由链（看图）───────────────────────────────────────
# 任何 OpenAI Vision 协议兼容的端点都能直连。按 slot 顺序组成"路由链"：
# 主力（slot 1）报错 / 超时 / 返回空 → 自动切到备用（slot 2）→ 最强保底（slot 3）。
# 有希也能在主力答得不够好时主动 escalate 到更强的备用模型。
#
# 默认推荐（中国大陆直连、省钱优先）：免费 GLM 主力 → 便宜 Qwen-Flash 备用
# → Qwen-Plus 最强保底。填上各自的 key 即生效；不想要某档就把它整组删掉。

#   主力 slot 1 —— 智谱 GLM-4.6V-Flash（永久免费，注册即送 key）
#   申请: https://bigmodel.cn  →  API Keys
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VISION_API_KEY=your_glm_key_here
VISION_MODEL=glm-4.6v-flash

#   备用 slot 2 —— 通义 Qwen3-VL-Flash（便宜，新用户有免费额度）
#   申请: https://bailian.console.aliyun.com  →  API-KEY
VISION_BASE_URL_2=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY_2=your_qwen_key_here
VISION_MODEL_2=qwen3-vl-flash

#   最强保底 slot 3 —— 通义 Qwen3-VL-Plus（qwen3 最强档，key 与 slot 2 相同）
VISION_BASE_URL_3=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY_3=your_qwen_key_here
VISION_MODEL_3=qwen3-vl-plus

# ─── 其它可选视觉端点（替换上面某个 slot，或加 _4 / _5 继续排队）──
#
#   # OpenAI（需代理）
#   # VISION_BASE_URL=https://api.openai.com/v1
#   # VISION_API_KEY=sk-...
#   # VISION_MODEL=gpt-4o-mini
#
#   # 火山方舟 / 豆包视觉（国产最强，付费）
#   # VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#   # VISION_API_KEY=...
#   # VISION_MODEL=doubao-1.5-vision-pro
#
#   # 通义千问 旗舰 VL（比 flash 更强，按量付费）
#   # VISION_MODEL=qwen-vl-max
#
#   # 硅基流动（聚合各家开源 VL，按 token 计费）
#   # VISION_BASE_URL=https://api.siliconflow.cn/v1
#   # VISION_API_KEY=sk-...
#   # VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct
#
#   # OpenRouter（聚合 Claude / Gemini / 各家闭源，需代理）
#   # VISION_BASE_URL=https://openrouter.ai/api/v1
#   # VISION_API_KEY=sk-or-...
#   # VISION_MODEL=google/gemini-2.0-flash-001
#
#   # Ollama 本地（免费离线，吃显存，8GB 跑 7B VL 量化）
#   # VISION_BASE_URL=http://localhost:11434/v1
#   # VISION_API_KEY=ollama
#   # VISION_MODEL=minicpm-v

# ─── 不用视觉 ───────────────────────────────────────────────────
# 不需要看图就把上面 VISION_* 的 key 全留占位符（图片功能会提示"未配置"，
# 不影响纯文字对话）。
